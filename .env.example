# HUGGINGFACE_TOKEN: Free API token from https://huggingface.co/settings/tokens
# Used for entity extraction via NER model (dslim/bert-base-NER)
# Create a token with "Inference Providers" permission enabled
HUGGINGFACE_TOKEN="hf_your_token_here"

# OPENROUTER_API_KEY: Free API key from https://openrouter.ai/keys
# Used for relationship extraction and node explanations (free tier model)
# No credit card required
OPENROUTER_API_KEY="sk-or-your_key_here"
